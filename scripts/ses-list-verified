#!/usr/bin/env bash
set -euo pipefail

REGION="us-west-2"

echo "=== SES account sending status (${REGION}) ==="
aws sesv2 get-account --region "${REGION}" \
  --query '{ProductionAccessEnabled: ProductionAccessEnabled, SendingEnabled: SendingEnabled, Quota: SendQuota}' \
  --output json
echo "# ProductionAccessEnabled: false -> we are in SES sandbox (can only send to verified identities)"

echo
echo "=== Verified identities ==="
aws sesv2 list-email-identities --region "${REGION}" --output table \
  --query 'EmailIdentities[].[IdentityType,IdentityName,VerifiedForSendingStatus,SendingEnabled]'

#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

# shellcheck disable=SC1091
source .env

BUCKET="${CYNDIBOT_INBOUND_BUCKET:-cyndibot-incoming-emails}"
PREFIX="${CYNDIBOT_INBOUND_PREFIX:-emails/}"
KEY="${1:-}"

if [[ -z "${KEY}" ]]; then
  KEY=$(aws s3api list-objects-v2 \
          --bucket "${BUCKET}" \
          --prefix "${PREFIX}" \
          --output json \
        | python3 -c "
import json, sys
d = json.load(sys.stdin)
objs = sorted(d.get('Contents') or [], key=lambda o: o['LastModified'], reverse=True)
if objs:
    print(objs[0]['Key'])
")
fi

if [[ -z "${KEY}" ]]; then
  echo "No inbound emails in s3://${BUCKET}/${PREFIX}" >&2
  exit 1
fi

echo "=== Running agent on s3://${BUCKET}/${KEY} ==="
echo

uv run python -m agent.inbound "${KEY}"

echo
echo "=== Latest Phoenix trace ==="
scripts/check-last-span

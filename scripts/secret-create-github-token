#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

# shellcheck disable=SC1091
source .env

if [ -z "${GITHUB_TOKEN:-}" ]; then
  echo "GITHUB_TOKEN not set in .env" >&2
  exit 1
fi

REGION="us-west-2"
SECRET_NAME="cyndibot/github-token"

# Idempotent: update if it exists, create if not.
if aws secretsmanager describe-secret --secret-id "${SECRET_NAME}" --region "${REGION}" >/dev/null 2>&1; then
  echo "secret ${SECRET_NAME} exists, updating value..."
  aws secretsmanager put-secret-value \
    --secret-id "${SECRET_NAME}" \
    --secret-string "${GITHUB_TOKEN}" \
    --region "${REGION}" \
    --output text \
    --query VersionId
else
  echo "creating secret ${SECRET_NAME}..."
  aws secretsmanager create-secret \
    --name "${SECRET_NAME}" \
    --description "GitHub fine-grained PAT for cyndibot to push to jessitron/cynditaylor-com. Scope: Contents R+W on that one repo." \
    --secret-string "${GITHUB_TOKEN}" \
    --region "${REGION}" \
    --output text \
    --query ARN
fi

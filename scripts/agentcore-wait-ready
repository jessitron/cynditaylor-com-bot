#!/usr/bin/env bash
set -euo pipefail

REGION="us-west-2"
RUNTIME_ID="${1:-cyndibot-o2gGSvB6Hz}"
DEADLINE=$(( $(date +%s) + 600 ))

while true; do
  STATUS=$(aws bedrock-agentcore-control get-agent-runtime \
    --region "${REGION}" \
    --agent-runtime-id "${RUNTIME_ID}" \
    --query 'status' \
    --output text)

  echo "$(date +%H:%M:%S) status=${STATUS}"

  case "${STATUS}" in
    READY)
      exit 0
      ;;
    CREATING|UPDATING)
      if (( $(date +%s) >= DEADLINE )); then
        echo "timed out after 600s; still ${STATUS}" >&2
        exit 1
      fi
      sleep 10
      ;;
    *)
      echo "unexpected status ${STATUS}; aborting" >&2
      exit 1
      ;;
  esac
done

#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

# shellcheck disable=SC1091
source .env
# INGEST_BEARER_TOKEN lives with the collector deployment, not the agent.
# shellcheck disable=SC1091
source collector/.env

ACCOUNT="414852377253"
REGION="us-west-2"
RUNTIME_ID="${1:-cyndibot-o2gGSvB6Hz}"
ROLE_ARN="arn:aws:iam::${ACCOUNT}:role/CyndibotAgentRuntime"
IMAGE_URI="${ACCOUNT}.dkr.ecr.${REGION}.amazonaws.com/cyndibot:latest"

# Resolve Boswell's function URL from AWS rather than hardcoding it.
BOSWELL_FUNCTION_URL=$(aws lambda get-function-url-config \
  --function-name boswell \
  --region "${REGION}" \
  --query FunctionUrl \
  --output text)
export BOSWELL_FUNCTION_URL

ENV_JSON=$(python3 scripts/_build_agentcore_env_json.py)
ARTIFACT_JSON=$(python3 -c 'import json,sys; print(json.dumps({"containerConfiguration":{"containerUri": sys.argv[1]}}))' "${IMAGE_URI}")
NETWORK_JSON='{"networkMode":"PUBLIC"}'
FS_JSON='[{"sessionStorage":{"mountPath":"/mnt/workspace"}}]'

echo "updating AgentCore runtime '${RUNTIME_ID}' in ${REGION}..."
echo "  image: ${IMAGE_URI}"
echo

aws bedrock-agentcore-control update-agent-runtime \
  --region "${REGION}" \
  --agent-runtime-id "${RUNTIME_ID}" \
  --agent-runtime-artifact "${ARTIFACT_JSON}" \
  --role-arn "${ROLE_ARN}" \
  --network-configuration "${NETWORK_JSON}" \
  --environment-variables "${ENV_JSON}" \
  --filesystem-configurations "${FS_JSON}"

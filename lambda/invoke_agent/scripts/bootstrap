#!/usr/bin/env bash
# One-time per AWS account/region: IAM execution role for the dispatcher Lambda.
# Idempotent — safe to re-run.

set -euo pipefail
cd "$(dirname "$0")/.."

# shellcheck disable=SC1091
source ./config.env

ACCOUNT=$(aws sts get-caller-identity --query Account --output text)

echo "==> account ${ACCOUNT}, region ${AWS_REGION}"

if aws iam get-role --role-name "${LAMBDA_ROLE_NAME}" >/dev/null 2>&1; then
  echo "iam: role ${LAMBDA_ROLE_NAME} already exists"
else
  echo "iam: creating role ${LAMBDA_ROLE_NAME}"
  aws iam create-role \
    --role-name "${LAMBDA_ROLE_NAME}" \
    --assume-role-policy-document file://../../infra/iam/cyndibot-invoke-agent-trust.json \
    --description "Execution role for the cyndibot SES->AgentCore dispatcher Lambda" \
    >/dev/null
fi

echo "iam: putting inline policy CyndibotInvokeAgentInline"
aws iam put-role-policy \
  --role-name "${LAMBDA_ROLE_NAME}" \
  --policy-name CyndibotInvokeAgentInline \
  --policy-document file://../../infra/iam/cyndibot-invoke-agent-policy.json

echo
echo "bootstrap complete."
echo "next: scripts/build && scripts/deploy && scripts/wire-into-ses"

# Module-level config. Checked into git.

LAMBDA_NAME=cyndibot-invoke-agent
LAMBDA_ROLE_NAME=CyndibotInvokeAgentLambda
AWS_REGION=us-west-2
LAMBDA_RUNTIME=python3.12
LAMBDA_ARCH=arm64
LAMBDA_MEMORY_MB=256
LAMBDA_TIMEOUT_S=60

# Where the agent runs.
AGENT_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-west-2:414852377253:runtime/cyndibot-o2gGSvB6Hz

# Where SES drops raw inbound MIME (S3 action runs first on the receipt rule).
INBOUND_BUCKET=cyndibot-incoming-emails
INBOUND_PREFIX=emails/

# Recipient filter — comma-separated usernames; any of these @AGENT_DOMAIN
# trigger an agent invoke. Other addresses on the domain still land in S3
# via the S3 action, but the Lambda no-ops on them. First entry is the
# canonical address used by smoke scripts.
AGENT_USERNAMES=cyndi,bot,robot,jeeves
AGENT_DOMAIN=cyndibot.jessitron.honeydemo.io

# SES receipt rule we attach to.
SES_RULESET=instruqt-email-ruleset
SES_RULE_NAME=cyndibot-inbound
SES_RECIPIENT_DOMAIN=cyndibot.jessitron.honeydemo.io

# Honeycomb dataset for one-event-per-email dispatcher records (separate from
# the AgentCore trace dataset). Auto-created on first write. The ingest key
# itself comes from .env at deploy time and is baked into Lambda env vars.
HONEYCOMB_DATASET=cyndibot-dispatcher

# Module-level config. Checked into git. Edit when reusing this module
# in another project (rename the Lambda, swap the ECR repo, etc).

COLLECTOR_NAME=cyndibot-collector
ECR_REPO=cyndibot-collector
LAMBDA_ROLE_NAME=CyndibotCollectorLambda
AWS_REGION=us-west-2
LAMBDA_ARCH=arm64
LAMBDA_MEMORY_MB=512
LAMBDA_TIMEOUT_S=30
